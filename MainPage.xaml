<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ClipboardMonitorWinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ClipboardMonitorWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Padding="28,18,28,24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页面标题和刷新时间 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock
                    FontSize="30"
                    FontWeight="SemiBold"
                    Text="剪贴板活动监视器" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="实时识别正在打开剪贴板和最近写入内容的程序" />
            </StackPanel>
            <TextBlock
                x:Name="LastRefreshText"
                Grid.Column="1"
                Margin="16,0,0,4"
                VerticalAlignment="Bottom"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="尚未刷新" />
        </Grid>

        <!-- InfoBar 会根据检测结果自动切换成功或警告状态 -->
        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Severity="Success"
            Title="当前没有程序持续打开剪贴板" />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="RefreshButton"
                Click="RefreshButton_Click"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock Text="立即刷新" />
                </StackPanel>
            </Button>

            <ToggleSwitch
                x:Name="AutoRefreshToggle"
                Grid.Column="1"
                VerticalAlignment="Center"
                Header="自动刷新"
                IsOn="True"
                Toggled="AutoRefreshToggle_Toggled" />

            <ComboBox
                x:Name="IntervalComboBox"
                Grid.Column="2"
                Width="132"
                Header="采样间隔"
                SelectedIndex="1"
                SelectionChanged="IntervalComboBox_SelectionChanged">
                <ComboBoxItem Content="100 毫秒" Tag="100" />
                <ComboBoxItem Content="250 毫秒" Tag="250" />
                <ComboBoxItem Content="500 毫秒" Tag="500" />
                <ComboBoxItem Content="1000 毫秒" Tag="1000" />
            </ComboBox>

            <Button
                Grid.Column="4"
                VerticalAlignment="Bottom"
                Click="ClearHistoryButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock Text="清空历史" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 三张状态卡片使用系统卡片颜色，自动适配浅色和深色主题 -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="OpenCard"
                MinHeight="190"
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="7">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="17" Glyph="&#xE8D4;" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="当前正在打开（潜在占用）" />
                    </StackPanel>
                    <TextBlock
                        x:Name="OpenProcessName"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="无" />
                    <TextBlock x:Name="OpenPidHandle" Text="PID：—    句柄：0x0" />
                    <TextBlock
                        x:Name="OpenWindowInfo"
                        Text="窗口：—"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="OpenPathInfo"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="路径：—"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                x:Name="OwnerCard"
                Grid.Column="1"
                MinHeight="190"
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="7">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="17" Glyph="&#xE8B7;" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="当前内容所有者（最近写入者）" />
                    </StackPanel>
                    <TextBlock
                        x:Name="OwnerProcessName"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="无" />
                    <TextBlock x:Name="OwnerPidHandle" Text="PID：—    句柄：0x0" />
                    <TextBlock
                        x:Name="OwnerWindowInfo"
                        Text="窗口：—"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="OwnerPathInfo"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="路径：—"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                x:Name="ViewerCard"
                Grid.Column="2"
                MinHeight="190"
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="7">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="17" Glyph="&#xE7B3;" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="旧式剪贴板查看器" />
                    </StackPanel>
                    <TextBlock
                        x:Name="ViewerProcessName"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="无" />
                    <TextBlock x:Name="ViewerPidHandle" Text="PID：—    句柄：0x0" />
                    <TextBlock
                        x:Name="ViewerWindowInfo"
                        Text="窗口：—"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="ViewerPathInfo"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="路径：—"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="18" FontWeight="SemiBold" Text="变化历史" />

            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Padding="12,0"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="时间" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="类型" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="进程" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontWeight="SemiBold" Text="PID" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontWeight="SemiBold" Text="窗口标题 / 类名" />
                        </Grid>
                    </Border>

                    <ListView
                        x:Name="HistoryListView"
                        Grid.Row="1"
                        ItemsSource="{x:Bind HistoryEntries, Mode=OneWay}"
                        SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="38" />
                                <Setter Property="Padding" Value="12,5" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HistoryEntry">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{x:Bind Foreground}" Text="{x:Bind Time}" />
                                    <TextBlock Grid.Column="1" Foreground="{x:Bind Foreground}" Text="{x:Bind Role}" />
                                    <TextBlock Grid.Column="2" Foreground="{x:Bind Foreground}" Text="{x:Bind ProcessName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Foreground="{x:Bind Foreground}" Text="{x:Bind ProcessId}" />
                                    <TextBlock Grid.Column="4" Foreground="{x:Bind Foreground}" Text="{x:Bind Window}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        x:Name="EmptyHistoryPanel"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE81C;" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="等待捕获剪贴板状态变化" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
